@{
    Layout = "~/Areas/Admin/Views/_Shared/_Layout.cshtml";
}
@using E_Commerce.Models

@functions {
    public MyDbContext db = new MyDbContext();
}

<div class="col-md-12">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white fw-bold">
            @(Model != null ? "Edit Advertisement" : "Add Advertisement")
        </div>

        <div class="card-body">
            <form method="post" enctype="multipart/form-data" action="@ViewBag.formAction">

                <!-- Name -->
                <div class="form-group row mb-3">
                    <label class="col-md-2 control-label fw-semibold">Name</label>
                    <div class="col-md-10">
                        <input type="text"
                               value="@(Model != null ? Model.Name : "")"
                               name="Name"
                               class="form-control"
                               required>
                    </div>
                </div>

                <!-- Position -->
                <div class="form-group row mb-3">
                    <label class="col-md-2 control-label fw-semibold">Position</label>
                    <div class="col-md-10">
                        <select name="Position" class="form-select" style="max-width:400px;">
                            <option @(Model != null && Model.Position == 1 ? "selected" : "") value="1">
                                Trang chủ (Dưới header)
                            </option>
                            <option @(Model != null && Model.Position == 1 ? "selected" : "") value="2">
                                Trang chủ (Dưới sản phẩm nổi bật)
                            </option>
                            <option @(Model != null && Model.Position == 2 ? "selected" : "") value="3">
                                Trang chủ (Trên tin tức nổi bật)
                            </option>
                            <option @(Model != null && Model.Position == 3 ? "selected" : "") value="4">
                                Trang sản phẩm - Bên trên footer
                            </option>
                        </select>
                    </div>
                </div>

                <!-- Photo Upload -->
                <div class="form-group row mb-3">
                    <label class="col-md-2 control-label fw-semibold">Photo</label>
                    <div class="col-md-10">
                        <input type="file" name="Photo" class="form-control" style="max-width:400px;">

                        @if (Model != null && !string.IsNullOrEmpty(Model.Photo))
                        {
                            <div class="mt-3">
                                <p class="text-muted mb-2">Current image:</p>
                                <img src="~/Upload/Adv/@Model.Photo"
                                     class="img-thumbnail"
                                     style="max-height: 150px; object-fit: cover;">
                            </div>
                        }
                    </div>
                </div>

                <!-- Submit Buttons -->
                <div class="form-group row mt-4">
                    <div class="col-md-2"></div>
                    <div class="col-md-10">
                        <button type="submit" class="btn btn-dark px-4">
                            <i class="fas fa-save me-1"></i>
                            @(Model != null ? "Update" : "Create")
                        </button>
                        <a href="/Admin/Adv/Index" class="btn btn-secondary px-4 ms-2">
                            <i class="fas fa-arrow-left me-1"></i> Back
                        </a>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>