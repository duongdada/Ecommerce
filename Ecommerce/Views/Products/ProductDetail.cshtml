@{
    Layout = "~/Views/Shared/LayoutDetail.cshtml";
}

@using E_Commerce.Models
@model ItemProduct

@functions {
    public MyDbContext db = new MyDbContext();

    //Lấy tên danh mục sản phẩm
    public string GetCategoryName(int _ProductId)
    {
        var record = (from category in db.Categories join category_product in db.CategoriesProducts on category.Id equals category_product.CategoryId join product in db.Products on category_product.ProductId equals product.Id where product.Id == _ProductId select category).FirstOrDefault();
        return record != null ? record.Name : "";
    }

    //Đánh giá số sao
    public string GetStar(int _ProductId, int _Star)
    {
        List<ItemRating> records = db.Rating.Where(item => item.ProductId == _ProductId && item.Star == _Star).ToList();
        return records.Count().ToString();
    }
}

<div class="container">
    <div class="row">
        <!-- Product Images -->
        <div class="col-12 col-lg-6">
            <div class="product-images">
                <div class="product-main-img">
                    <img src="~/Upload/Products/@Model.Photo" alt="@Model.Name" id="mainProductImg">
                </div>
                <div class="product-thumbnails">
                    <div class="thumbnail active">
                        <img src="~/Upload/Products/@Model.Photo" alt="@Model.Name">
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-12 col-lg-6">
            <div class="product-info">
                <h1 class="product-name">@Model.Name</h1>
                <div class="product-rating">
                    <a href="/Products/Rate/@Model.Id?star=1"><i class="fas fa-star"></i></a>
                    <a href="/Products/Rate/@Model.Id?star=2"><i class="fas fa-star"></i></a>
                    <a href="/Products/Rate/@Model.Id?star=3"><i class="fas fa-star"></i></a>
                    <a href="/Products/Rate/@Model.Id?star=4"><i class="fas fa-star"></i></a>
                    <a href="/Products/Rate/@Model.Id?star=5"><i class="fas fa-star"></i></a>
                    <span class="product-reviews">
                        (@(int.Parse(GetStar(Model.Id, 1)) + int.Parse(GetStar(Model.Id, 2)) + int.Parse(GetStar(Model.Id, 3)) + int.Parse(GetStar(Model.Id, 4)) + int.Parse(GetStar(Model.Id, 5))) reviews)
                    </span>
                </div>
                @if (Model.Discount > 0)
                {
                    <p class="product-price">
                        @string.Format("{0:N0} ₫", Model.Price - (Model.Price * Model.Discount) / 100)
                        <span style="text-decoration: line-through; font-size: 18px; color: #999; margin-left: 10px;">@string.Format("{0:N0} ₫", Model.Price)</span>
                    </p>
                }
                else
                {
                    <p class="product-price">@string.Format("{0:N0} ₫", Model.Price)</p>
                }
                <p class="product-description">
                    @Html.Raw(Model.Description)
                </p>

                <!-- Size Selection -->
                <div class="product-option">
                    <label class="option-label">Size:</label>
                    <div class="size-options">
                        <button class="size-btn" data-size="XS">XS</button>
                        <button class="size-btn" data-size="S">S</button>
                        <button class="size-btn active" data-size="M">M</button>
                        <button class="size-btn" data-size="L">L</button>
                        <button class="size-btn" data-size="XL">XL</button>
                    </div>
                </div>

                <!-- Color Selection -->
                <div class="product-option">
                    <label class="option-label">Color:</label>
                    <div class="color-options">
                        <button class="color-btn active" style="background-color: #000;" data-color="Black" aria-label="Black"></button>
                        <button class="color-btn" style="background-color: #fff; border: 1px solid #ededed;" data-color="White" aria-label="White"></button>
                        <button class="color-btn" style="background-color: #8b7355;" data-color="Beige" aria-label="Beige"></button>
                    </div>
                </div>

                <!-- Quantity -->
                <div class="product-option">
                    <label class="option-label">Quantity:</label>
                    <div class="quantity-selector">
                        <button class="qty-btn" id="decreaseQty">-</button>
                        <input type="number" class="qty-input" value="1" min="1" id="qtyInput">
                        <button class="qty-btn" id="increaseQty">+</button>
                    </div>
                </div>

                <!-- Actions -->
                <div class="product-actions">
                    <a href="/Cart/Buy/@Model.Id" class="add-to-cart-btn" style="text-decoration: none; display: block; text-align: center; line-height: 50px;">Add to Cart</a>
                    <button class="wishlist-btn" aria-label="Add to Wishlist">
                        <i class="far fa-heart"></i>
                    </button>
                </div>

                <!-- Meta Info -->
                <div class="product-meta">
                    <p><strong>SKU:</strong> @Model.Id</p>
                    <p><strong>Category:</strong> <a href="#">@GetCategoryName(Model.Id)</a></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Tabs -->
    <div class="product-tabs">
        <ul class="tabs-nav">
            <li class="tab-item active" data-tab="description">Description</li>
            <li class="tab-item" data-tab="additional">Additional Information</li>
            <li class="tab-item" data-tab="reviews">Reviews</li>
        </ul>
        <div class="tabs-content">
            <div class="tab-pane active" id="description">
                <h3>Product Description</h3>
                @Html.Raw(Model.Content)
            </div>
            <div class="tab-pane" id="additional">
                <table class="info-table">
                    <tr>
                        <td>Material</td>
                        <td>Premium Quality</td>
                    </tr>
                    <tr>
                        <td>Care Instructions</td>
                        <td>Follow care label</td>
                    </tr>
                    <tr>
                        <td>Origin</td>
                        <td>Imported</td>
                    </tr>
                    <tr>
                        <td>Fit</td>
                        <td>True to size</td>
                    </tr>
                </table>
            </div>
            <div class="tab-pane" id="reviews">
                <h3>Customer Reviews</h3>
                <div style="margin-top: 20px;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <tr style="border-bottom: 1px solid #ededed;">
                            <td style="padding: 15px 0; width: 80%;">
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                            </td>
                            <td style="padding: 15px 0;"><span class="badge bg-primary">@GetStar(Model.Id, 1) vote</span></td>
                        </tr>
                        <tr style="border-bottom: 1px solid #ededed;">
                            <td style="padding: 15px 0;">
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                            </td>
                            <td style="padding: 15px 0;"><span class="badge bg-warning">@GetStar(Model.Id, 2) vote</span></td>
                        </tr>
                        <tr style="border-bottom: 1px solid #ededed;">
                            <td style="padding: 15px 0;">
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                            </td>
                            <td style="padding: 15px 0;"><span class="badge bg-danger">@GetStar(Model.Id, 3) vote</span></td>
                        </tr>
                        <tr style="border-bottom: 1px solid #ededed;">
                            <td style="padding: 15px 0;">
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                            </td>
                            <td style="padding: 15px 0;"><span class="badge bg-info">@GetStar(Model.Id, 4) vote</span></td>
                        </tr>
                        <tr style="border-bottom: 1px solid #ededed;">
                            <td style="padding: 15px 0;">
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                                <i class="fas fa-star" style="color: #ffc107;"></i>
                            </td>
                            <td style="padding: 15px 0;"><span class="badge bg-success">@GetStar(Model.Id, 5) vote</span></td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    <div class="related-products">
        <h2 class="section-title">Related Products</h2>
        <div class="row g-4" id="relatedProducts">
            <!-- Related products will be loaded via JavaScript -->
        </div>
    </div>
</div>

<script>
    // Quantity buttons
    document.getElementById('decreaseQty').addEventListener('click', function() {
        var qtyInput = document.getElementById('qtyInput');
        var currentValue = parseInt(qtyInput.value);
        if (currentValue > 1) {
            qtyInput.value = currentValue - 1;
        }
    });

    document.getElementById('increaseQty').addEventListener('click', function() {
        var qtyInput = document.getElementById('qtyInput');
        var currentValue = parseInt(qtyInput.value);
        qtyInput.value = currentValue + 1;
    });

    // Size selection
    document.querySelectorAll('.size-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.size-btn').forEach(function(b) {
                b.classList.remove('active');
            });
            this.classList.add('active');
        });
    });

    // Color selection
    document.querySelectorAll('.color-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.color-btn').forEach(function(b) {
                b.classList.remove('active');
            });
            this.classList.add('active');
        });
    });

    // Tabs functionality
    document.querySelectorAll('.tab-item').forEach(function(tab) {
        tab.addEventListener('click', function() {
            var targetTab = this.getAttribute('data-tab');

            // Remove active class from all tabs and panes
            document.querySelectorAll('.tab-item').forEach(function(t) {
                t.classList.remove('active');
            });
            document.querySelectorAll('.tab-pane').forEach(function(p) {
                p.classList.remove('active');
            });

            // Add active class to clicked tab and corresponding pane
            this.classList.add('active');
            document.getElementById(targetTab).classList.add('active');
        });
    });

    // Thumbnail click
    document.querySelectorAll('.thumbnail').forEach(function(thumb) {
        thumb.addEventListener('click', function() {
            var imgSrc = this.querySelector('img').src;
            document.getElementById('mainProductImg').src = imgSrc;

            document.querySelectorAll('.thumbnail').forEach(function(t) {
                t.classList.remove('active');
            });
            this.classList.add('active');
        });
    });
</script>