<!-- Featured Categories -->
@{
    var categories = GetCategories();
}
@foreach (var category in categories)
{
    <section class="category-products">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Shop Collection</p>
                <h2 class="section-title">@category.Name</h2>
                <p class="section-description">Curated selections for the modern wardrobe</p>
            </div>
            <div class="row g-4">
                @{
                    var categoryProducts = GetProducts(category.Id);
                }
                @foreach (var product in categoryProducts)
                {
                    <div class="col-6 col-sm-6 col-md-4 col-lg-3">
                        <div class="product-card">
                            <div class="product-card-img-wrapper">
                                <a href="/Products/Detail/@product.Id">
                                    <img src="~/Upload/Products/@product.Photo" alt="@product.Name" title="@product.Name">
                                </a>
                                @if (product.Discount > 0)
                                {
                                    <span class="product-badge sale">-@product.Discount%</span>
                                }
                            </div>
                            <div class="product-card-info">
                                <a href="/Products/Detail/@product.Id" class="product-name">@product.Name</a>
                                <div class="product-price-wrapper">
                                    @if (product.Discount > 0)
                                    {
                                        <span class="product-price-old">@string.Format("{0:N0} ₫", product.Price)</span>
                                        <span class="product-price">@string.Format("{0:N0} ₫", product.Price - (product.Price * product.Discount) / 100)</span>
                                    }
                                    else
                                    {
                                        <span class="product-price">@string.Format("{0:N0} ₫", product.Price)</span>
                                    }
                                </div>
                                <a href="/Cart/Buy/@product.Id" class="product-add-cart">Add to Cart</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

