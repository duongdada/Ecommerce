<!-- Hot News Section -->
<section class="hot-news">
    <div class="container">
        <div class="section-header">
            <p class="section-subtitle">Latest Stories</p>
            <h2 class="section-title">Fashion News</h2>
            <p class="section-description">Stay updated with the latest trends and style tips</p>
        </div>
        <div class="row g-4">
            @{
                var hotNews = HotNews();
            }
            @foreach (var news in hotNews)
            {
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="news-card">
                        <div class="news-card-img">
                            <a href="/News/Detail/@news.Id">
                                <img src="~/Upload/News/@news.Photo" alt="@news.Name" title="@news.Name">
                            </a>
                        </div>
                        <div class="news-card-info">
                            <h3 class="news-title">
                                <a href="/News/Detail/@news.Id">@news.Name</a>
                            </h3>
                            <p class="news-description">@Html.Raw(news.Description)</p>
                            <a href="/News/Detail/@news.Id" class="news-read-more">
                                Read More
                                <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-5">
            <a href="/News" class="view-all-btn">View All News</a>
        </div>
    </div>
</section>

