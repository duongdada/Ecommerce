@{
    Layout = "~/Views/Shared/LayoutTrangChu.cshtml";
}
@using E_Commerce.Models
@model List<Item>

<!-- main -->
<div class="template-cart">
    <div class="container">
        <div class="cart-page-title">
            <h1>Giỏ Hàng</h1>
            <p>Quản lý sản phẩm trong giỏ hàng của bạn</p>
        </div>

        @if (Model != null && Model.Count > 0)
        {
            <form action="/Cart/Update" method="post">
                <div class="table-responsive">
                    <table class="table table-cart">
                        <thead>
                            <tr>
                                <th class="image">Ảnh sản phẩm</th>
                                <th class="name">Tên sản phẩm</th>
                                <th class="price">Giá bán lẻ</th>
                                <th class="quantity">Số lượng</th>
                                <th class="price">Thành tiền</th>
                                <th>Xóa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model)
                            {
                                <tr>
                                    <td>
                                        <img src="~/Upload/Products/@product.ProductRecord.Photo" class="img-responsive" alt="@product.ProductRecord.Name" />
                                    </td>
                                    <td>
                                        <a href="/Products/Detail/@product.ProductRecord.Id">@product.ProductRecord.Name</a>
                                    </td>
                                    <td class="price">
                                        @string.Format("{0:N0} ₫", product.ProductRecord.Price - (product.ProductRecord.Price * product.ProductRecord.Discount) / 100)
                                    </td>
                                    <td>
                                        <input type="number"
                                               min="1"
                                               class="input-control"
                                               value="@product.Quantity"
                                               name="product_@product.ProductRecord.Id"
                                               required>
                                    </td>
                                    <td class="price">
                                        <b>@string.Format("{0:N0} ₫", (product.ProductRecord.Price - (product.ProductRecord.Price * product.ProductRecord.Discount) / 100) * product.Quantity)</b>
                                    </td>
                                    <td>
                                        <a href="/Cart/Remove/@product.ProductRecord.Id" onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?')">
                                            <i class="fa fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="6">
                                    <a href="/Cart/Destroy"
                                       class="button pull-left"
                                       onclick="return confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng?')">
                                        Xóa toàn bộ
                                    </a>
                                    <a href="/Home" class="button pull-right black">
                                        Tiếp tục mua hàng
                                    </a>
                                    <input type="submit" class="button pull-right" value="Cập nhật">
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </form>

            <div class="total-cart">
                <strong>Tổng tiền thanh toán:</strong><br>
                <span style="font-size: 24px; font-weight: 600; color: #e74c3c;">
                    @string.Format("{0:N0} ₫", Cart.CartTotal(Context.Session))
                </span>
                <br><br>
                @* Kiểm tra đăng nhập trước khi cho phép thanh toán
                @if (!String.IsNullOrEmpty(Context.Session.GetString("customer_user_email")))
                {
                    <a href="/Cart/Checkout" class="button black">Thanh toán</a>
                }
                else
                {
                    <a href="/Account/Login" class="button black">Đăng nhập để thanh toán</a>
                } *@

                @*Không dùng kiểm tra đăng nhập để thanh toán nữa mà chuyển qua nhập thông tin thanh toán*@
                <a href="/Cart/Checkout" class="button black">Tiến hành thanh toán</a>
            </div>
        }
        else
        {
            <div class="cart-empty">
                <i class="fas fa-shopping-bag"></i>
                <h3>Giỏ hàng trống</h3>
                <p>Bạn chưa có sản phẩm nào trong giỏ hàng</p>
                <a href="/Home" class="button black">Tiếp tục mua sắm</a>
            </div>
        }
    </div>
</div>
<!-- end main -->

<script>
    // Update mini cart when page loads
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof loadMiniCart === 'function') {
            loadMiniCart();
        }
    });
</script>