@{
    Layout = "~/Views/Shared/LayoutAuth.cshtml";
}

<div class="auth-card">
    <div style="text-align: center; margin-bottom: 30px;">
        <div style="width: 80px; height: 80px; background: #e74c3c; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
            </svg>
        </div>
        <h1 class="auth-title">Xác Thực Email</h1>
        <p style="color: #666; font-size: 14px; margin-top: 10px;">
            Mã OTP đã được gửi đến<br />
            <strong style="color: #000;">@ViewBag.Email</strong>
        </p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        </div>
    }

    <form class="auth-form" method="post" action="/Account/VerifyResetOtpPost">
        <input type="hidden" name="email" value="@ViewBag.Email" />

        <div class="form-group">
            <label for="otp" class="form-label">Nhập mã OTP <span class="required">*</span></label>
            <input type="text"
                   id="otp"
                   name="otp"
                   class="form-input"
                   placeholder="Nhập 6 chữ số"
                   maxlength="6"
                   pattern="[0-9]{6}"
                   required
                   autocomplete="off"
                   style="text-align: center; font-size: 24px; letter-spacing: 8px; font-weight: bold;">
        </div>

        <div class="form-notice">
            <p style="text-align: center; color: #666; font-size: 13px;">
                <i class="fas fa-clock" style="margin-right: 5px;"></i>
                Mã OTP có hiệu lực trong <strong>10 phút</strong>
            </p>
        </div>

        <button type="submit" class="btn-submit">Xác Nhận</button>

        <div class="form-divider">
            <p class="redirect-text" style="text-align: center;">
                Không nhận được mã?
                <a href="/Account/ForgotPassword" class="link-bold">Gửi lại</a>
            </p>
        </div>

        <div class="form-divider">
            <p class="redirect-text" style="text-align: center;">
                <a href="/Account/Login" class="link-bold">
                    <i class="fas fa-arrow-left"></i> Quay lại đăng nhập
                </a>
            </p>
        </div>
    </form>
</div>

<style>
    .alert {
        padding: 14px 18px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-success {
        background-color: #d4edda;
        border: 1px solid #c3e6cb;
        color: #155724;
    }

    .alert-danger {
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
        color: #721c24;
    }

    .link-bold i {
        font-size: 12px;
        margin-right: 5px;
    }
</style>

<script>
    // Auto focus vào ô OTP
    document.getElementById('otp').focus();

    // Chỉ cho phép nhập số
    document.getElementById('otp').addEventListener('input', function(e) {
        this.value = this.value.replace(/[^0-9]/g, '');
    });
</script>