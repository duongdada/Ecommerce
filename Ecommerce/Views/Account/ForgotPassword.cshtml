@{
    Layout = "~/Views/Shared/LayoutAuth.cshtml";
}
@using E_Commerce.Models

<div class="auth-card">
    <h1 class="auth-title">Quên Mật Khẩu</h1>
    <p class="auth-subtitle">Nhập email của bạn để nhận mã OTP đặt lại mật khẩu</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        </div>
    }

    <form class="auth-form" method="post" action="/Account/ForgotPasswordPost">
        <div class="form-group">
            <label for="email" class="form-label">Email <span class="required">*</span></label>
            <input type="email" id="email" name="email" class="form-input" placeholder="example@email.com" required>
        </div>
        <button type="submit" class="btn-submit">Gửi mã OTP</button>
        <div class="form-divider">
            <p class="redirect-text">
                <a href="/Account/Login" class="link-bold">
                    <i class="fas fa-arrow-left"></i> Quay lại đăng nhập
                </a>
            </p>
        </div>
        <div class="form-divider">
            <p class="redirect-text">Bạn chưa có tài khoản? <a href="/Account/Register" class="link-bold">Đăng ký ngay</a></p>
        </div>
    </form>
</div>

<style>
    .auth-subtitle {
        text-align: center;
        color: #666;
        font-size: 14px;
        margin-bottom: 30px;
        line-height: 1.6;
    }

    .alert {
        padding: 14px 18px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-success {
        background-color: #d4edda;
        border: 1px solid #c3e6cb;
        color: #155724;
    }

    .alert-danger {
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
        color: #721c24;
    }

    .link-bold i {
        font-size: 12px;
        margin-right: 5px;
    }
</style>